{
  "mcpServers": {
    "servicenow": {
      "type": "stdio",
      "command": "${SNOW_MCP_CMD:-node}",
      "args": [
        "${SNOW_MCP_ENTRY:-snow-mcp.js}"
      ],
      "env": {
        "SN_INSTANCE": "${SN_INSTANCE}",
        "SN_USER": "${SN_USER}",
        "SN_PASS": "${SN_PASS}"
      }
    }
  }
}
