{
  "description": "hooks for tm-wardley — usage tracking",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/log-usage.sh agent"
          }
        ]
      }
    ]
  }
}
