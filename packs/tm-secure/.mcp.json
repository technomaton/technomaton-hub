{
  "mcpServers": {
    "jira": {
      "type": "stdio",
      "command": "${JIRA_MCP_CMD:-node}",
      "args": [
        "${JIRA_MCP_ENTRY:-jira-mcp.js}"
      ],
      "env": {
        "JIRA_BASE_URL": "${JIRA_BASE_URL}",
        "JIRA_TOKEN": "${JIRA_TOKEN}"
      }
    },
    "servicenow": {
      "type": "stdio",
      "command": "${SNOW_MCP_CMD:-node}",
      "args": [
        "${SNOW_MCP_ENTRY:-snow-mcp.js}"
      ],
      "env": {
        "SN_INSTANCE": "${SN_INSTANCE}",
        "SN_USER": "${SN_USER}",
        "SN_PASS": "${SN_PASS}"
      }
    }
  }
}